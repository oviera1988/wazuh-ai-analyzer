# ── Wazuh SIEM ──────────────────────────────────────────────────────────
# URL de tu instancia de Wazuh (API por defecto en puerto 55000)
WAZUH_URL=https://tu-servidor-wazuh:55000

# Usuario con permisos de lectura de alertas en Wazuh
WAZUH_USERNAME=wazuh-readonly

# Contraseña del usuario
WAZUH_PASSWORD=cambia_esta_contraseña

# Desactivar verificación SSL si usas certificados autofirmados (no recomendado en producción)
WAZUH_VERIFY_SSL=false

# Timeout de solicitudes HTTP en segundos
WAZUH_TIMEOUT=30

# ── Anthropic Claude ─────────────────────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar (claude-opus-4-5 recomendado para mejor análisis)
AI_MODEL=claude-opus-4-5

# Máximo de tokens por respuesta de la IA
AI_MAX_TOKENS=2000

# ── Configuración de la app ──────────────────────────────────────────────
# Alertas a descargar por ciclo de sincronización
MAX_ALERTS_PER_SYNC=500

# Alertas procesadas en paralelo por la IA (cuidado con los rate limits)
AI_BATCH_SIZE=5
